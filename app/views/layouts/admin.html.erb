<!DOCTYPE html>
<html>
  <head>
    <title>UNEL - Panel de Administración</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
  </head>

  <body class="min-h-screen bg-unel-blanco text-unel-negro">

    <div data-controller="admin-sidebar" class="flex min-h-screen">
      <%= render "admin/shared/sidebar" %>

      <div class="flex min-h-screen min-w-0 flex-1 flex-col">
        <%= render "admin/shared/topbar" %>

        <main class="flex-1 overflow-y-auto p-8">

          <% if notice %>
            <div data-controller="flash" class="mb-6 flex items-center justify-between rounded-xl border border-green-200 bg-green-50 p-4 text-sm font-semibold text-green-700 shadow-sm transition-all">
              <div><%= notice %></div>
              <button type="button" data-action="click->flash#close" class="ml-4 flex shrink-0 rounded-lg p-1 text-green-500 transition hover:bg-green-100 hover:text-green-700 focus:outline-none">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>

          <% if alert %>
            <div data-controller="flash" class="mb-6 flex items-center justify-between rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700 shadow-sm transition-all">
              <div><%= alert %></div>
              <button type="button" data-action="click->flash#close" class="ml-4 flex shrink-0 rounded-lg p-1 text-red-500 transition hover:bg-red-100 hover:text-red-700 focus:outline-none">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>

  </body>
</html>
