<% content_for :admin_section_key, "supplies" %>
<% content_for :admin_section_inner, "Insumos" %>
<% content_for :admin_search_placeholder, "Buscar insumos..." %>
<% content_for :admin_search_path, admin_supplies_path %>

<% total_supplies = @supplies.count %>
<% total_supply_cost = @supplies.sum { |supply| supply.effective_unit_cost.to_f } %>
<% average_supply_cost = total_supplies.positive? ? total_supply_cost / total_supplies : 0 %>
<% used_supplies = @supplies.count { |supply| supply.products.distinct.count.positive? } %>
<% unused_supplies = total_supplies - used_supplies %>

<section>
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-unel-carbon md:text-3xl">
        Insumos de empaque
      </h1>

      <p class="mt-2 max-w-2xl text-sm text-unel-humo">
        Administra frascos, tapas y etiquetas usados para calcular el costo unitario real de cada producto.
      </p>
    </div>
  </div>

  <div class="flex w-full flex-wrap gap-4 xl:flex-nowrap justify-around">
    <%= render "admin/shared/stat_card",
      title: "Total insumos",
      value: total_supplies,
      description: "Insumos registrados" %>

    <%= render "admin/shared/stat_card",
      title: "Costo promedio",
      value: number_to_currency(average_supply_cost, unit: "$", precision: 0, delimiter: "."),
      description: "Costo unitario real promedio" %>

    <%= render "admin/shared/stat_card",
      title: "Usados en productos",
      value: used_supplies,
      description: "Insumos asociados a productos" %>

    <%= render "admin/shared/stat_card",
      title: "Sin uso",
      value: unused_supplies,
      description: "Insumos aún no asociados" %>
  </div>

  <div data-controller="table-filter table-sort" class="rounded-lg mt-4 border border-unel-crema-2 bg-white shadow-sm">
    <div class="border-b border-unel-crema-2 px-4 py-5 sm:px-6">
      <h2 class="text-lg font-bold text-unel-carbon">
        Insumos registrados
      </h2>

      <p class="mt-1 text-sm text-unel-humo">
        Lista de insumos con categoría, tamaño y costo por unidad.
      </p>
    </div>

    <% if @supplies.any? %>
      <div class="flex flex-col gap-4 border-b border-unel-crema-2 px-4 py-4 sm:px-6 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-wrap items-center gap-3">
          <%= link_to "Nuevo insumo", new_admin_supply_path,
            class: "rounded-xl bg-unel-verde px-4 py-2 text-center text-sm font-semibold text-unel-blanco transition hover:bg-unel-carbon" %>
        </div>

        <div class="flex w-full flex-col gap-3 sm:flex-row sm:items-center md:w-auto">
          <div class="flex w-full items-center gap-2 rounded-xl border border-unel-crema-2 px-4 py-2 sm:w-auto">
            <label for="supplies_sort" class="shrink-0 text-xs font-semibold text-unel-humo">
              Ordenar por:
            </label>

            <select
              id="supplies_sort"
              data-table-sort-target="select"
              data-action="change->table-sort#sort"
              class="w-full bg-transparent text-sm font-semibold text-unel-verde outline-none sm:w-52"
            >
              <option value="">Orden original</option>
              <option value="name_asc">Nombre A-Z</option>
              <option value="name_desc">Nombre Z-A</option>
              <option value="cost_desc">Costo mayor a menor</option>
              <option value="cost_asc">Costo menor a mayor</option>
              <option value="stock_desc">Más usados primero</option>
              <option value="stock_asc">Menos usados primero</option>
            </select>
          </div>

          <div class="w-full rounded-xl bg-unel-crema px-4 py-2 sm:w-auto">
            <input
              type="search"
              placeholder="Buscar insumo..."
              data-table-filter-target="input"
              data-action="input->table-filter#filter"
              class="w-full bg-transparent text-sm text-unel-negro outline-none placeholder:text-unel-humo sm:w-64"
            >
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-220 w-full text-left text-sm">
          <thead class="bg-unel-verde text-xs uppercase tracking-wide text-unel-blanco">
            <tr>
              <th class="px-6 py-4 font-semibold">Nombre</th>
              <th class="px-6 py-4 font-semibold">Tipo</th>
              <th class="px-6 py-4 font-semibold">Tamaño</th>
              <th class="px-6 py-4 font-semibold">Compra</th>
              <th class="px-6 py-4 font-semibold">Costo unitario real</th>
              <th class="px-6 py-4 font-semibold">Usado en</th>
              <th class="px-6 py-4 text-right font-semibold">Acciones</th>
            </tr>
          </thead>

          <tbody data-table-sort-target="body" class="divide-y divide-unel-crema-2">
            <% @supplies.each do |supply| %>
              <% used_count = supply.products.distinct.count %>
              <% purchase_text = supply.unit_measure == "pack" ? "Pack de #{supply.pack_quantity || 0}" : "Unidad" %>

              <tr
                data-table-filter-target="row"
                data-table-sort-target="row"
                data-search-text="<%= [supply.name, supply.category_name, supply.descriptor, purchase_text, supply.effective_unit_cost, used_count].join(' ') %>"
                data-sort-name="<%= supply.name %>"
                data-sort-cost="<%= supply.effective_unit_cost || 0 %>"
                data-sort-stock="<%= used_count %>"
                class="transition hover:bg-unel-crema/50"
              >
                <td class="px-6 py-4 font-semibold text-unel-negro">
                  <%= supply.name %>
                </td>

                <td class="px-6 py-4 text-unel-humo">
                  <%= supply.category_name %>
                </td>

                <td class="px-6 py-4 text-unel-humo">
                  <%= supply.descriptor.presence || "Sin información" %>
                </td>

                <td class="px-6 py-4 text-unel-humo">
                  <%= purchase_text %>
                </td>

                <td class="px-6 py-4 font-semibold text-unel-verde">
                  <%= number_to_currency(supply.effective_unit_cost || 0, unit: "$", precision: 0, delimiter: ".") %>
                </td>

                <td class="px-6 py-4 text-unel-humo">
                  <%= pluralize(used_count, "producto", "productos") %>
                </td>

                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-3">
                    <%= link_to "Editar", edit_admin_supply_path(supply),
                      class: "text-sm font-semibold text-unel-dorado transition hover:text-unel-dorado-2" %>

                    <%= button_to "Eliminar", admin_supply_path(supply),
                      method: :delete,
                      form: { data: { turbo_confirm: "¿Eliminar #{supply.name}?" } },
                      class: "text-sm font-semibold text-red-500 transition hover:text-red-700 cursor-pointer" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div data-table-filter-target="emptyState" class="hidden border-t border-unel-crema-2 px-4 py-12 text-center sm:px-6">
        <p class="text-lg font-bold text-unel-negro">
          No encontramos insumos con esa búsqueda
        </p>

        <p class="mx-auto mt-2 max-w-md text-sm text-unel-humo">
          Intenta buscar por nombre, tipo, tamaño, compra, costo unitario o uso en productos.
        </p>

        <button
          type="button"
          data-action="table-filter#clear"
          class="mt-6 rounded-xl border border-unel-crema-2 px-4 py-2 text-sm font-semibold text-unel-humo transition hover:border-unel-dorado hover:text-unel-dorado"
        >
          Limpiar búsqueda
        </button>
      </div>
    <% else %>
      <div class="px-4 py-12 text-center sm:px-6">
        <p class="text-lg font-bold text-unel-negro">
          Todavía no hay insumos registrados
        </p>

        <p class="mx-auto mt-2 max-w-md text-sm text-unel-humo">
          Crea frascos, tapas y etiquetas para completar el costo unitario de los productos.
        </p>

        <div class="mt-6">
          <%= link_to "Crear primer insumo", new_admin_supply_path,
            class: "rounded-xl bg-unel-verde px-4 py-2 text-sm font-semibold text-unel-blanco transition hover:bg-unel-carbon" %>
        </div>
      </div>
    <% end %>
  </div>
</section>