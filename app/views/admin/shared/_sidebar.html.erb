<aside
  data-admin-sidebar-target="sidebar"
  class="fixed inset-y-0 left-0 z-40 h-screen w-64 shrink-0 -translate-x-full overflow-y-auto bg-unel-carbon px-4 py-6 text-unel-crema shadow-xl transition-all duration-300 lg:static lg:z-auto lg:h-auto lg:translate-x-0 lg:overflow-hidden"
>
  <div data-admin-sidebar-target="brand" class="mb-10 flex items-center gap-3">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-unel-verde text-sm font-bold text-unel-blanco">
      U
    </div>

    <div data-admin-sidebar-target="label">
      <p class="text-xs font-semibold uppercase tracking-wide text-unel-dorado">
        Panel administrativo
      </p>

      <h1 class="mt-1 text-2xl font-bold text-unel-blanco">
        Unel Admin
      </h1>
    </div>
  </div>

  <nav data-admin-sidebar-target="nav" class="space-y-8">
    <div>
      <div data-admin-sidebar-target="sectionHeader" class="mb-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-unel-humo">
          <span data-admin-sidebar-target="label">
            Principal
          </span>
        </p>

        <!--<div data-admin-sidebar-target="sectionDivider" class="mx-auto hidden h-px w-8 bg-unel-humo"></div>-->
      </div>

      <%= link_to "/admin/dashboard",
         data: { active_path: "/admin/dashboard", admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>
        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Dashboard
        </span>
      <% end %>
    </div>

    <div>
      <div data-admin-sidebar-target="sectionHeader" class="mb-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-unel-humo">
          <span data-admin-sidebar-target="label">
            Gestión
          </span>
        </p>

        <div data-admin-sidebar-target="sectionDivider" class="mx-auto hidden h-px w-8 bg-unel-humo"></div>
      </div>

      <%= link_to admin_products_path,
        data: { active_path: admin_products_path, admin_sidebar_target: "navItem" },
        class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>

        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Productos y costos
        </span>
      <% end %>

      <%= link_to "/admin/ingredients",
         data: { active_path: "/admin/ingredients", admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>

        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5v9.75A2.25 2.25 0 0 1 18 19.5H6a2.25 2.25 0 0 1-2.25-2.25V7.5m16.5 0A2.25 2.25 0 0 0 18 5.25H6A2.25 2.25 0 0 0 3.75 7.5m16.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-6 3.625a2.25 2.25 0 0 1-2.36 0l-6-3.625a2.25 2.25 0 0 1-1.07-1.916V7.5" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Ingredientes
        </span>
      <% end %>

      <%= link_to admin_supplies_path,
         data: { active_path: admin_supplies_path, admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>

        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5 12 3 3 7.5m18 0-9 4.5m9-4.5v9L12 21m0-9L3 7.5m9 4.5v9M3 7.5v9L12 21" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Insumos
        </span>
      <% end %>

      <%= link_to "/admin/inventory_movements",
         data: { active_path: "/admin/inventory_movements", admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>
        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Inventario
        </span>
      <% end %>

      <%= link_to "/admin/customers",
         data: { active_path: "/admin/customers", admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>
        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Clientes
        </span>
      <% end %>

      <%= link_to "/admin/orders",
         data: { active_path: "/admin/orders", admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>

        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6M6.75 3.75h10.5A2.25 2.25 0 0 1 19.5 6v15l-3.75-2.25L12 21l-3.75-2.25L4.5 21V6a2.25 2.25 0 0 1 2.25-2.25Z" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Pedidos
        </span>
      <% end %>
    </div>

    <div>
      <div data-admin-sidebar-target="sectionHeader" class="mb-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-unel-humo">
          <span data-admin-sidebar-target="label">
            Finanzas
          </span>
        </p>

        <div data-admin-sidebar-target="sectionDivider" class="mx-auto hidden h-px w-8 bg-unel-humo"></div>
      </div>

      <%= link_to "/admin/finances",
         data: { active_path: "/admin/finances", admin_sidebar_target: "navItem" },
         class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>
        <span data-admin-sidebar-target="activeIndicator" class="absolute left-0 hidden h-7 w-1 rounded-full bg-unel-dorado-2"></span>

        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Finanzas
        </span>
      <% end %>
    </div>

    <div>
      <div data-admin-sidebar-target="sectionHeader" class="mb-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-unel-humo">
          <span data-admin-sidebar-target="label">
            Canal público
          </span>
        </p>

        <div data-admin-sidebar-target="sectionDivider" class="mx-auto hidden h-px w-8 bg-unel-humo"></div>
      </div>

      <%= link_to products_path,
        class: "relative mt-2 flex w-full items-center justify-start gap-3 px-4 py-3 text-unel-crema hover:text-unel-dorado transition-all text-sm font-medium" do %>
        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Catálogo público
        </span>
      <% end %>
    </div>
  </nav>

  <div data-admin-sidebar-target="logoutWrapper" class="mt-10 border-t border-unel-humo pt-6">
    <%= button_to destroy_admin_session_path,
      method: :delete,
      class: "w-full rounded-xl border border-red-400 px-4 py-3 text-sm font-semibold text-red-400 transition hover:bg-red-500 hover:text-white cursor-pointer" do %>

      <span class="flex items-center justify-center gap-3">
        <span class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
          </svg>
        </span>

        <span data-admin-sidebar-target="label">
          Salir del panel
        </span>
      </span>
    <% end %>
  </div>
</aside>

<div
  data-admin-sidebar-target="overlay"
  data-action="click->admin-sidebar#closeMobileMenu"
  class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"
></div>
