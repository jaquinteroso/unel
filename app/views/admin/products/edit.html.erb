<% content_for :admin_section_key, "products" %>
<% content_for :admin_section_inner, "Editar producto" %>
<% content_for :admin_search_placeholder, "Buscar productos..." %>
<% content_for :admin_search_path, admin_products_path %>

<% product = @product %>
<% ingredients = @ingredients || [] %>

<section>
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-unel-dorado">
      Productos y costos
      </p>

      <h1 class="mt-2 text-2xl font-bold text-unel-carbon md:text-3xl">
        Editar <%= product.name.presence || "Producto" %>
      </h1>

      <p class="mt-2 max-w-2xl text-sm text-unel-humo">
      Modifica la información general, actualiza la receta o ajusta los costos.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <%= link_to "Ver detalle", admin_product_path(product), class: "rounded-xl bg-unel-crema px-4 py-2 text-sm font-semibold text-unel-carbon transition hover:bg-unel-crema-2" %>

      <%= button_to "Eliminar", admin_product_path(product), 
        method: :delete, 
        form: { data: { turbo_confirm: "¿Estás seguro de eliminar este producto?" } },
        class: "rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-100 cursor-pointer" %>

      <%= link_to "Volver", admin_products_path, class: "rounded-xl border border-unel-crema-2 px-4 py-2 text-center text-sm font-semibold text-unel-humo transition hover:border-unel-dorado hover:text-unel-dorado" %>
    </div>
  </div>

  <%= form_with model: [:admin, product], local: true, data: { controller: "price-preview disable-enter", action: "keydown->disable-enter#prevent" }, class: "space-y-6" do |form| %>

    <% if product.errors.any? %>
      <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm">
        <h3 class="text-sm font-bold text-red-700">No se pudo guardar el producto:</h3>
        <ul class="mt-2 list-disc pl-5 text-sm font-medium text-red-600">
          <% product.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid gap-6 xl:grid-cols-[1.4fr_0.9fr]">
      <div class="space-y-6">

        <div class="rounded-lg border border-unel-crema-2 bg-white shadow-sm">
          <div class="border-b border-unel-crema-2 px-4 py-5 sm:px-6">
            <h2 class="text-lg font-bold text-unel-carbon">Información general</h2>
          </div>

          <div class="grid gap-5 px-4 py-5 sm:px-6">
            <div>
              <%= form.label :name, "Nombre del producto *", class: "block text-sm font-semibold text-unel-carbon" %>
              <%= form.text_field :name, class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado" %>
            </div>

            <div>
              <%= form.label :image, "Fotografía del producto", class: "block text-sm font-semibold text-unel-carbon" %>
              <%= form.file_field :image, class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-2 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado file:mr-4 file:rounded-lg file:border-0 file:bg-unel-crema file:px-4 file:py-2 file:text-sm file:font-semibold file:text-unel-dorado hover:file:bg-unel-crema-2" %>
            </div>

            <div>
              <%= form.label :description, "Descripción", class: "block text-sm font-semibold text-unel-carbon" %>
              <%= form.rich_text_area :description, class: "mt-2 block w-full rounded-xl border border-unel-crema-2 bg-unel-blanco p-4 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado min-h-[150px]" %>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-unel-crema-2 bg-white shadow-sm">
          <div class="border-b border-unel-crema-2 px-4 py-5 sm:px-6">
            <h2 class="text-lg font-bold text-unel-carbon">Receta e ingredientes</h2>
          </div>

          <div class="space-y-4 px-4 py-5 sm:px-6">
            <div data-controller="recipe-items">
              <div data-recipe-items-target="container" class="space-y-4">

                <% product.recipe_items.each_with_index do |recipe_item, index| %>
                  <div data-recipe-item class="grid gap-4 rounded-xl border border-unel-crema-2 bg-unel-blanco p-4 md:grid-cols-[1fr_160px_auto]">
                    <input type="hidden" name="product[recipe_items_attributes][<%= index %>][id]" value="<%= recipe_item.id %>">

                    <div>
                      <label class="block text-sm font-semibold text-unel-carbon">Ingrediente</label>
                      <select name="product[recipe_items_attributes][<%= index %>][ingredient_id]" data-action="change->price-preview#calculate" class="mt-2 w-full rounded-xl border border-unel-crema-2 bg-white px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado">
                        <option value="">Selecciona un ingrediente</option>
                        <% ingredients.each do |ingredient| %>
                          <option value="<%= ingredient.id %>" data-cost="<%= ingredient.cost_per_unit || 0 %>" <%= 'selected' if ingredient.id == recipe_item.ingredient_id %>>
                          <%= ingredient.name %> (<%= ingredient.unit_measure %>)
                          </option>
                        <% end %>
                      </select>
                    </div>

                    <div>
                      <label class="block text-sm font-semibold text-unel-carbon">Cantidad</label>
                      <input type="number" name="product[recipe_items_attributes][<%= index %>][quantity]" value="<%= recipe_item.quantity %>" min="0" step="0.01" data-action="input->price-preview#calculate" class="mt-2 w-full rounded-xl border border-unel-crema-2 bg-white px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado">
                    </div>

                    <div class="flex items-end">
                      <button type="button" data-action="recipe-items#remove" class="w-full rounded-xl border border-red-200 px-4 py-3 text-sm font-semibold text-red-500 transition hover:bg-red-50 md:w-auto">Quitar</button>
                      <input type="hidden" name="product[recipe_items_attributes][<%= index %>][_destroy]" value="false" data-destroy-field>
                    </div>
                  </div>
                <% end %>
              </div>

              <template data-recipe-items-target="template">
                <div data-recipe-item class="grid gap-4 rounded-xl border border-unel-crema-2 bg-unel-blanco p-4 md:grid-cols-[1fr_160px_auto]">
                  <div>
                    <label class="block text-sm font-semibold text-unel-carbon">Ingrediente</label>
                    <select name="product[recipe_items_attributes][__INDEX__][ingredient_id]" data-action="change->price-preview#calculate" class="mt-2 w-full rounded-xl border border-unel-crema-2 bg-white px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado">
                      <option value="">Selecciona un ingrediente</option>
                      <% ingredients.each do |ingredient| %>
                        <option value="<%= ingredient.id %>" data-cost="<%= ingredient.cost_per_unit || 0 %>"><%= ingredient.name %> (<%= ingredient.unit_measure %>)</option>
                      <% end %>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-unel-carbon">Cantidad</label>
                    <input type="number" name="product[recipe_items_attributes][__INDEX__][quantity]" min="0" step="0.01" data-action="input->price-preview#calculate" class="mt-2 w-full rounded-xl border border-unel-crema-2 bg-white px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado">
                  </div>
                  <div class="flex items-end">
                    <button type="button" data-action="recipe-items#remove" class="w-full rounded-xl border border-red-200 px-4 py-3 text-sm font-semibold text-red-500 transition hover:bg-red-50 md:w-auto">Quitar</button>
                  </div>
                </div>
              </template>

              <button type="button" data-action="recipe-items#add" class="mt-4 rounded-xl border border-unel-crema-2 px-4 py-2 text-sm font-semibold text-unel-humo transition hover:border-unel-dorado hover:text-unel-dorado">
                Agregar otro ingrediente
              </button>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-unel-crema-2 bg-white shadow-sm">
          <div class="border-b border-unel-crema-2 px-4 py-5 sm:px-6">
            <h2 class="text-lg font-bold text-unel-carbon">Insumos de empaque</h2>

            <p class="mt-1 text-sm text-unel-humo">
              Define el frasco, la tapa y la etiqueta usados por una unidad del producto.
            </p>
          </div>

          <div class="grid gap-4 px-4 py-5 sm:px-6">
            <% if @supplies_by_category.values.any?(&:any?) %>
              <%= form.fields_for :product_supplies do |supply_fields| %>
                <% product_supply = supply_fields.object %>
                <% role = product_supply.role %>
                <% supplies = @supplies_by_category[role] || [] %>

                <div data-product-supply class="rounded-xl border border-unel-crema-2 bg-unel-blanco p-4">
                  <%= supply_fields.hidden_field :id if product_supply.persisted? %>
                  <%= supply_fields.hidden_field :role %>
                  <%= supply_fields.hidden_field :quantity, value: product_supply.quantity || 1, data: { supply_quantity: true } %>

                  <%= supply_fields.label :supply_id, ProductSupply::ROLES[role], class: "block text-sm font-semibold text-unel-carbon" %>
                  <%= supply_fields.select :supply_id,
                    supplies.map { |supply| [supply.display_name, supply.id, { data: { cost: supply.cost_per_unit || 0 } }] },
                    { prompt: "Selecciona #{ProductSupply::ROLES[role].downcase}" },
                    data: {
                      price_preview_target: "supplySelect",
                      action: "change->price-preview#calculate"
                    },
                    class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-white px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado" %>

                  <% if supplies.empty? %>
                    <p class="mt-2 text-xs text-amber-700">
                      No hay insumos registrados para este tipo.
                    </p>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <div class="rounded-xl border border-dashed border-unel-crema-2 bg-unel-blanco px-6 py-8 text-center">
                <p class="text-sm font-bold text-unel-carbon">
                  Todavía no hay insumos disponibles
                </p>

                <p class="mx-auto mt-2 max-w-md text-sm text-unel-humo">
                  Crea frascos, tapas y etiquetas para completar el costo unitario del producto.
                </p>

                <%= link_to "Ir a insumos", admin_supplies_path,
                  class: "mt-5 inline-flex rounded-xl border border-unel-crema-2 px-4 py-2 text-sm font-semibold text-unel-humo transition hover:border-unel-dorado hover:text-unel-dorado" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="rounded-lg border border-unel-crema-2 bg-white shadow-sm">
          <div class="border-b border-unel-crema-2 px-4 py-5 sm:px-6">
            <h2 class="text-lg font-bold text-unel-carbon">Costos y precios</h2>
            <p class="mt-1 text-sm text-unel-humo">
              El costo unitario se calcula automáticamente desde receta e insumos.
            </p>
          </div>
          <div class="space-y-5 px-4 py-5 sm:px-6">
            <div>
              <label class="block text-sm font-semibold text-unel-carbon">
                Costo unitario calculado
              </label>

              <div data-price-preview-target="summaryCost" class="mt-2 rounded-xl border border-unel-crema-2 bg-unel-crema px-4 py-3 text-sm font-bold text-unel-verde">
                <%= number_to_currency(product.calculated_cost || 0, unit: "$", precision: 0, delimiter: ".") %>
              </div>

              <p class="mt-2 text-xs text-unel-humo">
                Suma ingredientes, frasco, tapa y etiqueta. No se escribe manualmente.
              </p>
            </div>
            <div>
              <%= form.label :margin, "Margen (%)", class: "block text-sm font-semibold text-unel-carbon" %>
              <%= form.number_field :margin, min: 0, step: 0.1, data: { price_preview_target: "margin", action: "input->price-preview#calculate" }, class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado" %>
            </div>
            <div>
              <label class="block text-sm font-semibold text-unel-carbon">
                Precio sugerido
              </label>

              <div
                  data-price-preview-target="suggestedPrice"
                  class="mt-2 rounded-xl border border-unel-crema-2 bg-unel-crema px-4 py-3 text-sm font-semibold text-unel-humo"
                  >
                  Pendiente
              </div>

                <p class="mt-2 text-xs text-unel-humo">
                Este valor se calcula automáticamente con el costo unitario y el margen ingresado.
                </p>
            </div>
            <div>
              <%= form.label :price, "Precio final", class: "block text-sm font-semibold text-unel-carbon" %>
              <%= form.number_field :price, min: 0, step: 1, data: { price_preview_target: "price", action: "input->price-preview#calculate" }, class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado" %>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-unel-crema-2 bg-white shadow-sm">
          <div class="border-b border-unel-crema-2 px-4 py-5 sm:px-6">
            <h2 class="text-lg font-bold text-unel-carbon">Inventario</h2>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <%= form.label :stock, "Stock inicial", class: "block text-sm font-semibold text-unel-carbon" %>
            <%= form.number_field :stock, min: 0, step: 1, data: { price_preview_target: "stock", action: "input->price-preview#calculate" }, class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado" %>
          </div>
        </div>

        <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
          <%= link_to "Cancelar", admin_products_path, class: "rounded-xl border border-unel-crema-2 px-4 py-2 text-center text-sm font-semibold text-unel-humo transition hover:border-unel-dorado hover:text-unel-dorado" %>
          <%= form.submit "Guardar cambios", class: "rounded-xl bg-unel-dorado px-4 py-2 text-sm font-semibold text-white transition hover:bg-yellow-600 cursor-pointer" %>
        </div>
      </div>
    </div>
  <% end %>
</section>
