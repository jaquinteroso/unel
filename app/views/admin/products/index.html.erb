<% content_for :admin_section, "Productos y costos" %>
<% content_for :admin_search_placeholder, "Buscar productos..." %>
<% content_for :admin_search_path, admin_products_path %>

<section>
  <div class="mb-8 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-unel-negro">
        Productos y costos
      </h1>

      <p class="mt-2 max-w-2xl text-sm text-unel-humo">
        Administra recetas, costos unitarios, márgenes y precios sugeridos de las conservas.
      </p>
    </div>

    <%= link_to "Nuevo producto", new_admin_product_path,
      class: "rounded-xl bg-unel-verde px-4 py-2 text-sm font-semibold text-unel-blanco transition hover:bg-unel-carbon" %>
  </div>

  <div class="rounded-2xl border border-unel-crema-2 bg-unel-crema p-8">
    Aquí irá la tabla de productos.
  </div>
</section>