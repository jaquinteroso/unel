<% content_for :admin_section_key, "products" %>
<% content_for :admin_section_inner, "Productos y costos" %>
<% content_for :admin_search_placeholder, "Buscar productos..." %>
<% content_for :admin_search_path, admin_products_path %>

<% product_stats = (@product_stats || {}).with_indifferent_access %>
<!--
Después, cuando tengas Dashboard, en su vista pondrías:

<% content_for :admin_section_key, "dashboard" %>
<% content_for :admin_section, "Dashboard" %>

Cuando tengas Inventario:

<% content_for :admin_section_key, "inventory" %>
<% content_for :admin_section, "Inventario" %>
-->

<section>
  <div class="mb-8 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-unel-carbon">
        Productos y costos
      </h1>

      <p class="mt-2 max-w-2xl text-sm text-unel-humo">
        Administra recetas, costos unitarios, márgenes y precios sugeridos de las conservas.
      </p>
    </div>
  </div>

  <div class="flex w-full gap-4">
    <%= render "admin/shared/stat_card",
    title: "Total productos",
    value: product_stats[:total_products] || 0,
    description: "Productos registrados" %>

  <%= render "admin/shared/stat_card",
    title: "Costo promedio",
    value: number_to_currency(product_stats[:average_cost] || 0, unit: "$", precision: 0, delimiter: "."),
    description: "Costo unitario promedio" %>

  <%= render "admin/shared/stat_card",
    title: "Sin precio final",
    value: product_stats[:without_final_price] || 0,
    description: "Productos pendientes de precio" %>

  <%= render "admin/shared/stat_card",
    title: "Stock bajo",
    value: product_stats[:low_stock] || 0,
    description: "Productos bajo el mínimo" %>
  </div>
  
</section>