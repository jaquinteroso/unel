<% content_for :title, "Nueva contraseña | Unel" %>

<div class="rounded-2xl border border-unel-crema-2 bg-white p-6 shadow-sm sm:p-8">
  <p class="text-sm font-semibold uppercase tracking-[0.16em] text-unel-dorado">Seguridad de la cuenta</p>
  <h1 class="mt-2 text-3xl font-bold text-unel-carbon">Crear nueva contraseña</h1>
  <p class="mt-3 text-sm leading-6 text-unel-humo">Usa una contraseña de al menos <%= @minimum_password_length || 6 %> caracteres.</p>

  <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :put, class: "mt-8 space-y-5" do |form| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= form.hidden_field :reset_password_token %>

    <div>
      <%= form.label :password, "Nueva contraseña", class: "block text-sm font-semibold text-unel-carbon" %>
      <%= form.password_field :password,
        autofocus: true,
        autocomplete: "new-password",
        required: true,
        class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado focus:ring-2 focus:ring-unel-dorado/20" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirmar nueva contraseña", class: "block text-sm font-semibold text-unel-carbon" %>
      <%= form.password_field :password_confirmation,
        autocomplete: "new-password",
        required: true,
        class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition focus:border-unel-dorado focus:ring-2 focus:ring-unel-dorado/20" %>
    </div>

    <%= form.submit "Actualizar contraseña", class: "w-full cursor-pointer rounded-xl bg-unel-verde px-5 py-3 text-sm font-bold text-white transition hover:bg-unel-carbon focus:outline-none focus:ring-2 focus:ring-unel-dorado focus:ring-offset-2" %>
  <% end %>
</div>
