<% content_for :title, "Iniciar sesión | Unel" %>

<div class="rounded-2xl border border-unel-crema-2 bg-white p-6 shadow-sm sm:p-8">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-unel-dorado">Acceso seguro</p>
    <h1 class="mt-2 text-3xl font-bold text-unel-carbon">Iniciar sesión</h1>
    <p class="mt-3 text-sm leading-6 text-unel-humo">Ingresa con la cuenta entregada por la administración de Unel.</p>
  </div>

  <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :email, "Correo electrónico", class: "block text-sm font-semibold text-unel-carbon" %>
      <%= form.email_field :email,
        autofocus: true,
        autocomplete: "email",
        required: true,
        placeholder: "admin@unel.cl",
        class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition placeholder:text-unel-humo focus:border-unel-dorado focus:ring-2 focus:ring-unel-dorado/20" %>
    </div>

    <div>
      <div class="flex items-center justify-between gap-4">
        <%= form.label :password, "Contraseña", class: "block text-sm font-semibold text-unel-carbon" %>
        <%= link_to "Olvidé mi contraseña", new_password_path(resource_name), class: "text-xs font-semibold text-unel-dorado transition hover:text-unel-verde" %>
      </div>
      <%= form.password_field :password,
        autocomplete: "current-password",
        required: true,
        placeholder: "Ingresa tu contraseña",
        class: "mt-2 w-full rounded-xl border border-unel-crema-2 bg-unel-blanco px-4 py-3 text-sm text-unel-carbon outline-none transition placeholder:text-unel-humo focus:border-unel-dorado focus:ring-2 focus:ring-unel-dorado/20" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex cursor-pointer items-center gap-3 text-sm text-unel-humo">
        <%= form.check_box :remember_me, class: "h-4 w-4 rounded border-unel-crema-2 text-unel-verde focus:ring-unel-dorado" %>
        Mantener mi sesión iniciada
      </label>
    <% end %>

    <%= form.submit "Entrar al panel", class: "w-full cursor-pointer rounded-xl bg-unel-verde px-5 py-3 text-sm font-bold text-white transition hover:bg-unel-carbon focus:outline-none focus:ring-2 focus:ring-unel-dorado focus:ring-offset-2" %>
  <% end %>

  <div class="mt-6 rounded-xl border border-unel-crema-2 bg-unel-crema/50 px-4 py-3">
    <p class="text-xs leading-5 text-unel-humo"><strong class="text-unel-carbon">Acceso restringido:</strong> las cuentas administrativas son creadas únicamente por el equipo autorizado.</p>
  </div>
</div>

<p class="mt-6 text-center text-sm text-unel-humo">
  <%= link_to "Volver al catálogo", root_path, class: "font-semibold text-unel-dorado transition hover:text-unel-verde" %>
</p>
